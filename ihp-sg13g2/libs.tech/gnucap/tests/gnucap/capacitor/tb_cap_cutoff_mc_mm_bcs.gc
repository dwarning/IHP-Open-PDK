// load modelgen plugins
load mgsim

verilog
// include corners and testbench
include ../../../models/cornerCAP.va
include ./tb_cap_cutoff_mc.va
include ./consts.params

options numdgt=9

// instantiate best-case corner and testbench module
cap_bcs corner_cap();
tb_cap_ac_mc #(.mm_ok(1)) tb(out1, out2);

// run mismatch mc ac sweep
// TODO: replace redirection > /dev/null with cleaner solution
// TODO: store C1 amd C2 in vectors and print them as colums
.sweep 1000 run 1 1000
  reseed // increments global seed by one
  store ac v(out1) v(out2)
  dc > /dev/null
  ac dec 1e3 1e6 1e7 basic > /dev/null
  measure fcut1 = cross(probe="v(out1)" cross=0.707 rise first) > /dev/null
  measure fcut2 = cross(probe="v(out2)" cross=0.707 rise first) > /dev/null
  parameter C1 = {1.0 / (M_TWO_PI * fcut1 * 1e5)}
  parameter C2 = {1.0 / (M_TWO_PI * fcut2 * 1e5)}
  eval C1
  eval C2
go
