// load modelgen plugins
load mgsim

verilog
// include corners and testbench modules
include ../../../models/cornerMOSlv.va
include ./tb_moslv_nmos_id_vd.va

// instantiate tt corner and testbench
moslv_tt corner_moslv();
tb_nmos_dc #(.rfmode(0), .vd(vd), .vg(vg), .w(1.2u), .ng(4)) tb(d, g);

// run dc sweep
parameter real vd = 0.0;
parameter real vg = 0.0;
print dc v(g) i(tb.sd) iter(0)
dc vd 0 1.2 0.02 vg 0.2 1.2 0.2 basic
status notime
