// load modelgen plugins
load mgsim

verilog
// include corners and testbench
include ../../../models/cornerMOSlv.va
include ./tb_moslv_inv.va

// instantiate sf corner and testbench
moslv_sf corner_moslv();
tb_moslv_inv #(.rfmode(0), .vin_dc(vin_sweep)) tb(in, out);

// run dc sweep
parameter real vin_sweep = 0.0;
print dc v(out) i(tb.vdd_src) iter(0)
dc vin_sweep 0 1.2 0.02 basic
status notime


