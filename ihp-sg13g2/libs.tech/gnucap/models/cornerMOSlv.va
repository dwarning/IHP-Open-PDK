//------------------------------------------------------------------------------
//
// NOTE: use only typical mean file (this file) for Monte Carlo simulations of process tolerance!
//
// hint: using spectre, add this file as a model file in analog artist;
//   using spectreS, add it under Environment/Include with syntax=spectre
//
// Corner naming scheme: typical mean=tt, worst case=ss, best case=ff, combinations sf, fs, ...
// Digit Devices


// Monte-Carlo begin ---------------------------------------------
//
// NOTE: default of all   parameters should be 1.0
// NOTE: deviations from 1.0 are used to fit statistical results
//
//
//
//
//------------------------------------------------------------------------------
//
// Low Voltage (lv) MOS Transistors
//
// Model:                                PSP 103.6
// Date:                                 10.03.2020
// Lot:                                  EDJ809
// WAFER:                                06
// CHIP Nr:                              x=3, y=9
// Device:                               SG13G2
// Maximum drain-source voltage:         1.5
// Measurement data:
// Nom. Temperature  (TNOM):             27 grd C
// Meas. Temperature (TEMP):             27 grd C
// Valid range for model:                L = (0.13 - 10)um
//                                       W = (0.15 - 10)um
//
//------------------------------------------------------------------------------

// Moslv corner modules
// Ported the ngspice/models/cornerMOSlv.lib to Verilog-A
// Modifications:
// - removed mismatch corners; mismatch device variants are implemented via
//   paramset overloading
// - moved global process-variation parameters from `sg13g2_moslv_stat.lib` to
//   into statistical corner-related definitions are kept in a single file
// - renamed the norm suffix to nom for nominal values for consitency across
//   corners
// (c) Lukas Deutz 2026

// **************** CORNER_LIB OF sg13g2_lv TT MODEL ****************
// Typical
module moslv_tt();
    // nmos
    localparam real sg13g2_lv_nmos_vfbo = 1.0;
    localparam real sg13g2_lv_nmos_ctl = 1.2080;
    localparam real sg13g2_lv_nmos_rsw1 = 0.7200;
