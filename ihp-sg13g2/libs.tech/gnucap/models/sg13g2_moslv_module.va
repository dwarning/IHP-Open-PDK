    sg13g2_lv_nmos_psp #(.rfmode(rfmode), .w(w), .l(l), .ng(ng), .mult(m), .as(as), .ad(ad), .ps(ps), .pd(pd), .dta(trise), .ngcon(2), .delvto(0), .factuo(1)) Nsg13_lv_nmos(d, g, s, b);
