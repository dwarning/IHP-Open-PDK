    .bfn = 0.9086;
    .nsig_rsh = corner_res.nsig_rsh_rhigh;
    .nsig_w   = corner_res.nsig_w_rhigh;
    .nsig_l   = corner_res.nsig_l_rhigh;
    .sig_rsh  = res_stat_param.drsh_rhigh;
    .sig_w    = res_stat_param.dw_rhigh;
    .sig_l    = res_stat_param.dl_rhigh;
    .nsmm_rsh = res_mm.nsmm_rsh_rhigh;
    .nsmm_w   = res_mm.nsmm_w_rhigh;
    .nsmm_l   = res_mm.nsmm_l_rhigh;
    .smm_rsh  = res_mm.drsh_mm_rhigh;
    .smm_w    = res_mm.dw_mm_rhigh;
    .smm_l    = res_mm.dl_mm_rhigh;
endparamset

