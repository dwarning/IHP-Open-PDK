    .gth0 = 1e-12;
    .gthc = 1e-12;
    .gthp = 2e-6;
    .gtha = 6e-6;
    .cth0 = 0;
    .cthp = 0;
    .ctha = 594e-15;
    .cthc = 0;
    .kfn = 4.601e-11;
    .afn = 1.886;
    .bfn = 0.9963;
    .nsig_rsh = corner_res.nsig_rsh_rppd;
    .nsig_w   = corner_res.nsig_w_rppd;
    .nsig_l   = corner_res.nsig_l_rppd;
    .sig_rsh  = res_stat_param.drsh_rppd;
    .sig_w    = res_stat_param.dw_rppd;
    .sig_l    = res_stat_param.dl_rppd;
endparamset

